{
  "name": "planning-pharmacie",
  "version": "1.0.0",
  "description": "Planning de pharmacie — application multi-postes avec serveur intégré",
  "main": "electron/main.js",
  "author": "Planning Pharmacie",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "server": "node server/index.js",
    "client:dev": "vite",
    "client:build": "vite build",
    "electron:start": "electron .",
    "electron:build": "electron-builder",
    "electron:build:win": "electron-builder --win",
    "electron:build:mac": "electron-builder --mac",
    "build": "npm run client:build && npm run electron:build",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "express-session": "^1.18.0",
    "session-file-store": "^1.5.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^0.383.0",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0"
  },
  "build": {
    "appId": "fr.planning-pharmacie.app",
    "productName": "Planning Pharmacie",
    "copyright": "Planning Pharmacie",
    "directories": {
      "output": "dist-installer",
      "buildResources": "assets"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "client/dist/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "PlanningPharmacie-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Planning Pharmacie",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "license": "LICENSE.txt",
      "language": "1036"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business",
      "artifactName": "PlanningPharmacie-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "Planning Pharmacie ${version}",
      "writeUpdateInfo": false
    }
  }
}
